rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /patient_summaries/{patientId} {
      allow read: if request.auth != null;
    }

    match /patient_experiences/{patientId} {
      allow read: if request.auth != null;
    }

    match /coach_conversations/{patientId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.patient_id == patientId;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.patient_id == patientId
          && request.resource.data.auth_uid == request.auth.uid
          && (
            request.resource.data.role == 'user'
            || request.resource.data.role == 'assistant'
          )
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000;
      }
    }
  }
}
